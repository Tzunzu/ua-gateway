<Window
    x:Class="UAGateway.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:UAGateway.UI.Controls"
    Title="UA Gateway"
    mc:Ignorable="d">
    <Grid x:Name="RootLayout"
          Padding="24"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource ShellToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <MenuBar Background="{ThemeResource ShellToolbarBackgroundBrush}">
                    <MenuBarItem Title="File">
                        <MenuFlyoutItem Text="New" IsEnabled="False" />
                        <MenuFlyoutItem Text="Open" IsEnabled="False" />
                        <MenuFlyoutItem Text="Save" IsEnabled="False" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Exit" IsEnabled="False" />
                    </MenuBarItem>

                    <MenuBarItem Title="Edit">
                        <MenuFlyoutItem Text="Undo" IsEnabled="False" />
                        <MenuFlyoutItem Text="Redo" IsEnabled="False" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Cut" IsEnabled="False" />
                        <MenuFlyoutItem Text="Copy" IsEnabled="False" />
                        <MenuFlyoutItem Text="Paste" IsEnabled="False" />
                    </MenuBarItem>

                    <MenuBarItem Title="View">
                        <MenuFlyoutItem Text="Dashboard" IsEnabled="False" />
                        <MenuFlyoutItem Text="Connections" IsEnabled="False" />
                        <MenuFlyoutItem Text="Server Settings" IsEnabled="False" />
                        <MenuFlyoutItem Text="Logs" IsEnabled="False" />
                        <MenuFlyoutItem Text="Live Output" IsEnabled="False" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Refresh" IsEnabled="False" />
                    </MenuBarItem>

                    <MenuBarItem Title="Settings">
                        <MenuFlyoutSubItem Text="Theme">
                            <MenuFlyoutItem Text="System"
                                            Click="ThemeSystem_Click" />
                            <MenuFlyoutItem Text="Light"
                                            Click="ThemeLight_Click" />
                            <MenuFlyoutItem Text="Dark"
                                            Click="ThemeDark_Click" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSubItem Text="Palette">
                            <MenuFlyoutItem Text="WinUI"
                                            Click="PaletteWinUI_Click" />
                            <MenuFlyoutItem Text="VS Code"
                                            Click="PaletteVSCode_Click" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Application Settings" IsEnabled="False" />
                        <MenuFlyoutItem Text="Certificates and Trust" IsEnabled="False" />
                        <MenuFlyoutItem Text="Diagnostics Paths" IsEnabled="False" />
                    </MenuBarItem>

                    <MenuBarItem Title="Help">
                        <MenuFlyoutItem Text="Documentation"
                                        Click="DocumentationHelp_Click" />
                        <MenuFlyoutItem Text="About UA Gateway" IsEnabled="False" />
                    </MenuBarItem>
                </MenuBar>
            </Border>

            <TabView Grid.Row="1"
                     x:Name="MainTabs"
                     Background="{ThemeResource ShellTabStripBackgroundBrush}"
                     BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                     BorderThickness="1">
                <TabView.Resources>
                    <SolidColorBrush x:Key="TabViewItemHeaderBackground"
                                     Color="{ThemeResource ShellTabHeaderBackgroundColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected"
                                     Color="{ThemeResource ShellTabHeaderBackgroundSelectedColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPointerOver"
                                     Color="{ThemeResource ShellTabHeaderBackgroundPointerOverColor}" />
                </TabView.Resources>
                <TabViewItem x:Name="DashboardTab"
                             Header="Dashboard">
                    <controls:DashboardOverview x:Name="DashboardOverviewView" />
                </TabViewItem>

                <TabViewItem x:Name="ConnectionsTab"
                             Header="Connections">
                    <controls:ConnectionsEditor x:Name="ConnectionsEditorView" />
                </TabViewItem>

                <TabViewItem x:Name="ServerSettingsTab"
                             Header="Server Settings">
                    <controls:ServerSettingsEditor x:Name="ServerSettingsEditorView" />
                </TabViewItem>

                <TabViewItem x:Name="LogsTab"
                             Header="Logs">
                    <controls:LogsViewer x:Name="LogsViewerView" />
                </TabViewItem>

                <TabViewItem x:Name="LiveOutputTab"
                             Header="Live Output">
                    <controls:LiveOutputViewer x:Name="LiveOutputViewerView" />
                </TabViewItem>

            </TabView>

            <Border Grid.Row="2"
                    Padding="10,8"
                    Background="{ThemeResource ShellToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusServiceText"
                               Grid.Column="0"
                               FontWeight="SemiBold"
                               Text="Service: Unknown" />
                    <TextBlock x:Name="StatusIpcText"
                               Grid.Column="1"
                               Text="UI-Service: Disconnected" />
                    <TextBlock x:Name="StatusClientsText"
                               Grid.Column="2"
                               Text="Clients connected: n/a" />
                    <TextBlock x:Name="StatusServersText"
                               Grid.Column="3"
                               Text="Servers connected: 0/0" />
                    <TextBlock x:Name="StatusFailuresText"
                               Grid.Column="4"
                               Text="Failures: 0" />
                        <StackPanel x:Name="StatusActionsPanel"
                            Grid.Column="5"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                        <Button x:Name="StatusPrimaryActionButton"
                            Click="StatusPrimaryActionButton_Click"
                            Visibility="Collapsed" />
                        <Button x:Name="StatusSecondaryActionButton"
                            Click="StatusSecondaryActionButton_Click"
                            Visibility="Collapsed" />
                        </StackPanel>
                    <TextBlock x:Name="StatusUpdatedText"
                               Grid.Column="6"
                               HorizontalAlignment="Right"
                               Opacity="0.8"
                               Text="Updated: n/a" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
