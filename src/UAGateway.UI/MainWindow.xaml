<Window
    x:Class="UAGateway.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="24">
        <StackPanel Spacing="8">
            <TextBlock Text="UA Gateway"
                       FontSize="30"
                       FontWeight="SemiBold" />
            <TextBlock Text="Windows frontend built with WinUI 3."
                       Opacity="0.75" />

            <Border Margin="0,16,0,0"
                    Padding="12"
                    Background="#11000000"
                    CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Security Bootstrap Diagnostics"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SecurityStatusText" />
                    <TextBlock x:Name="SecurityReasonText"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="SecurityCountsText" />
                    <TextBlock x:Name="SecurityThumbprintText"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="SecurityUpdatedText"
                               Opacity="0.75" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
