<Window
    x:Class="UAGateway.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="UA Gateway"
    mc:Ignorable="d">
    <Grid x:Name="RootLayout"
                    Padding="0"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <Grid RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

                <Border x:Name="AppTitleBar"
                        Grid.Row="0"
                        Padding="0"
                        Background="{ThemeResource ShellToolbarBackgroundBrush}"
                        BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="0">
                    <Grid Height="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="AppTitleBarLeftInsetColumn" Width="0" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="AppTitleBarRightInsetColumn" Width="0" />
                        </Grid.ColumnDefinitions>

                        <Grid x:Name="AppTitleBarDragRegion"
                              Grid.Column="1"
                              Margin="16,0,0,0"
                              ColumnSpacing="12"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                               <Image Grid.Column="0"
                                   Width="40"
                                   Height="40"
                                   VerticalAlignment="Center">
                                <Image.Source>
                                    <SvgImageSource UriSource="ms-appx:///Assets/Brand/gateway-icon.svg" />
                                </Image.Source>
                            </Image>

                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource ShellPrimaryTextBrush}"
                                       Text="UA Gateway" />
                        </Grid>

                        <Grid Grid.Column="2" />
                    </Grid>
                </Border>

            <Border Grid.Row="1"
                    Background="{ThemeResource ShellTabStripBackgroundBrush}"
                    BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <NavigationView x:Name="ShellNavigation"
                                Background="{ThemeResource ShellTabStripBackgroundBrush}"
                                BackRequested="ShellNavigation_BackRequested"
                                IsBackButtonVisible="Visible"
                                IsSettingsVisible="True"
                                PaneDisplayMode="Left"
                                SelectionChanged="ShellNavigation_SelectionChanged">
                    <NavigationView.Header>
                        <Grid x:Name="ShellHeaderContainer"
                              ColumnSpacing="{ThemeResource ShellHeaderCommandGap}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                                <TextBlock x:Name="ShellHeaderText"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource ShellPrimaryTextBrush}"
                                       Text="Dashboard" />
                        </Grid>
                    </NavigationView.Header>

                    <NavigationView.MenuItems>
                        <NavigationViewItem x:Name="DashboardNavItem"
                                            Content="Dashboard"
                                            Tag="Dashboard">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Home" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem x:Name="ConnectionsNavItem"
                                            Content="Connections"
                                            Tag="Connections">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="World" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem x:Name="ServerSettingsNavItem"
                                            Content="Server Settings"
                                            Tag="ServerSettings">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Setting" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem x:Name="LogsNavItem"
                                            Content="Logs"
                                            Tag="Logs">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Document" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>

                        <NavigationViewItem x:Name="LiveOutputNavItem"
                                            Content="Live Output"
                                            Tag="LiveOutput">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Preview" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationView.MenuItems>

                        <Frame x:Name="ShellFrame" />
                </NavigationView>
            </Border>

                <Border Grid.Row="2"
                    Padding="{ThemeResource ShellStatusPadding}"
                    Background="{ThemeResource ShellToolbarBackgroundBrush}"
                    BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                        BorderThickness="1,1,1,0"
                        CornerRadius="0">
                <Grid ColumnSpacing="{ThemeResource ShellStatusColumnGap}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusServiceText"
                               Grid.Column="0"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource ShellPrimaryTextBrush}"
                               Text="Service: Unknown" />
                    <TextBlock x:Name="StatusClientsText"
                               Grid.Column="1"
                               Foreground="{ThemeResource ShellSubtleTextBrush}"
                               Text="Clients connected: n/a" />
                    <TextBlock x:Name="StatusServersText"
                               Grid.Column="2"
                               Foreground="{ThemeResource ShellSubtleTextBrush}"
                               Text="Servers connected: 0/0" />
                    <TextBlock x:Name="StatusFailuresText"
                               Grid.Column="3"
                               Foreground="{ThemeResource ShellSubtleTextBrush}"
                               Text="Failures: 0" />
                    <TextBlock x:Name="StatusUpdatedText"
                               Grid.Column="4"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource ShellSubtleTextBrush}"
                               Text="Updated: n/a" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
