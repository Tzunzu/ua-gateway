<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <Color x:Key="BrandAccentColor">#FF0B5FFF</Color>
            <Color x:Key="BrandAccentSoftColor">#FFE6EFFF</Color>
            <Color x:Key="ShellToolbarBackgroundColor">#FFF5F7FA</Color>
            <Color x:Key="ShellTabStripBackgroundColor">#FFEEF2F6</Color>
            <Color x:Key="ShellSurfaceBorderColor">#FFCCD5E1</Color>
            <Color x:Key="ShellSurfaceMutedColor">#FFE3E8EF</Color>
            <Color x:Key="ShellPrimaryTextColor">#FF0F172A</Color>
            <Color x:Key="ShellSubtleTextColor">#FF334155</Color>
            <Color x:Key="ShellCommandForegroundColor">#FFFFFFFF</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <Color x:Key="BrandAccentColor">#FF0B5FFF</Color>
            <Color x:Key="BrandAccentSoftColor">#FFE6EFFF</Color>
            <Color x:Key="ShellToolbarBackgroundColor">#FFF5F7FA</Color>
            <Color x:Key="ShellTabStripBackgroundColor">#FFEEF2F6</Color>
            <Color x:Key="ShellSurfaceBorderColor">#FFCCD5E1</Color>
            <Color x:Key="ShellSurfaceMutedColor">#FFE3E8EF</Color>
            <Color x:Key="ShellPrimaryTextColor">#FF0F172A</Color>
            <Color x:Key="ShellSubtleTextColor">#FF334155</Color>
            <Color x:Key="ShellCommandForegroundColor">#FFFFFFFF</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <Color x:Key="BrandAccentColor">#FF5AA2FF</Color>
            <Color x:Key="BrandAccentSoftColor">#FF1E2C42</Color>
            <Color x:Key="ShellToolbarBackgroundColor">#FF121A24</Color>
            <Color x:Key="ShellTabStripBackgroundColor">#FF0E1620</Color>
            <Color x:Key="ShellSurfaceBorderColor">#FF2A3A4E</Color>
            <Color x:Key="ShellSurfaceMutedColor">#FF1A2635</Color>
            <Color x:Key="ShellPrimaryTextColor">#FFE2E8F0</Color>
            <Color x:Key="ShellSubtleTextColor">#FF93A4B8</Color>
            <Color x:Key="ShellCommandForegroundColor">#FF08101A</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <SolidColorBrush x:Key="BrandAccentBrush" Color="{ThemeResource BrandAccentColor}" />
    <SolidColorBrush x:Key="BrandAccentSoftBrush" Color="{ThemeResource BrandAccentSoftColor}" />
    <SolidColorBrush x:Key="ShellToolbarBackgroundBrush" Color="{ThemeResource ShellToolbarBackgroundColor}" />
    <SolidColorBrush x:Key="ShellTabStripBackgroundBrush" Color="{ThemeResource ShellTabStripBackgroundColor}" />
    <SolidColorBrush x:Key="ShellSurfaceBorderBrush" Color="{ThemeResource ShellSurfaceBorderColor}" />
    <SolidColorBrush x:Key="ShellSurfaceMutedBrush" Color="{ThemeResource ShellSurfaceMutedColor}" />
    <SolidColorBrush x:Key="ShellPrimaryTextBrush" Color="{ThemeResource ShellPrimaryTextColor}" />
    <SolidColorBrush x:Key="ShellSubtleTextBrush" Color="{ThemeResource ShellSubtleTextColor}" />
    <SolidColorBrush x:Key="ShellCommandForegroundBrush" Color="{ThemeResource ShellCommandForegroundColor}" />
</ResourceDictionary>
