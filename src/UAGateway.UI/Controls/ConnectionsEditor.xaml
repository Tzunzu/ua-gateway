<UserControl
    x:Class="UAGateway.UI.Controls.ConnectionsEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Padding="12"
                Spacing="8">
        <TextBlock x:Name="ConnectionsHeaderText"
                   FontWeight="SemiBold" />

        <Grid ColumnSpacing="16"
              RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Stretch"
                                Spacing="8">
                        <TextBlock Text="Connections"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <Button Content="Add Connection"
                                HorizontalAlignment="Right"
                                Click="AddConnectionDraft_Click" />
                    </StackPanel>

                    <ListView x:Name="ConnectionsList"
                              BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                              BorderThickness="1"
                              MinHeight="420"
                              SelectionChanged="ConnectionsList_SelectionChanged" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Connection Settings"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectedConnectionHintText"
                               Opacity="0.75"
                               Text="Select a connection to edit its configuration." />

                    <TextBlock Text="Connection ID"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="SelectedConnectionIdTextBox"
                             IsReadOnly="True"
                             PlaceholderText="No connection selected" />

                    <TextBlock Text="Display Name"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="DraftDisplayNameTextBox"
                             PlaceholderText="Display name"
                             LostFocus="DraftDisplayNameTextBox_LostFocus" />

                    <TextBlock Text="Endpoint URL"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="DraftEndpointUrlTextBox"
                             PlaceholderText="opc.tcp://host:port/path"
                             LostFocus="DraftEndpointUrlTextBox_LostFocus" />

                    <ToggleSwitch x:Name="DraftEnabledToggle"
                                  Header="Enabled"
                                  Toggled="DraftEnabledToggle_Toggled" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Button x:Name="ReloadConfigurationButton"
                            Content="Reload Configuration"
                                Click="ReloadConnectionsDraft_Click" />
                        <Button x:Name="ApplyConfigurationButton"
                            Content="Apply Configuration"
                                Click="ApplyConnectionsDraft_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock x:Name="ConnectionsApplyStatusText"
                   TextWrapping="WrapWholeWords"
                   Opacity="0.8" />
    </StackPanel>
</UserControl>