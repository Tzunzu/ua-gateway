<UserControl
    x:Class="UAGateway.UI.Controls.LogsViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Padding="12"
                Spacing="8">
        <Border Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock Text="Diagnostics log filters"
                           FontWeight="SemiBold" />

                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <ComboBox x:Name="SeverityFilterComboBox"
                              Width="160"
                              SelectedIndex="0">
                        <x:String>All Severities</x:String>
                        <x:String>Information</x:String>
                        <x:String>Warning</x:String>
                        <x:String>Error</x:String>
                        <x:String>Critical</x:String>
                    </ComboBox>
                    <TextBox x:Name="CategoryFilterTextBox"
                             Width="220"
                             PlaceholderText="Category contains..." />
                    <TextBox x:Name="EventIdFilterTextBox"
                             Width="180"
                             PlaceholderText="Event ID contains..." />
                    <Button Content="Apply"
                            Click="ApplyLogFilters_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Padding="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock x:Name="LogsSummaryText"
                           Opacity="0.75" />
                <ListView x:Name="LogsList"
                          BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                          BorderThickness="1"
                          Height="320" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>