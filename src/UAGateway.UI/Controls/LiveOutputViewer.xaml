<UserControl
    x:Class="UAGateway.UI.Controls.LiveOutputViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Padding="12"
                Spacing="8">
        <Border Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button x:Name="PauseResumeButton"
                        Content="Pause"
                        Click="PauseResumeButton_Click" />
                <Button Content="Clear"
                        Click="ClearButton_Click" />
                <ToggleSwitch x:Name="AutoScrollToggle"
                              Header="Auto-scroll"
                              IsOn="True" />
                <TextBlock x:Name="LiveStatusText"
                           VerticalAlignment="Center"
                           Opacity="0.8"
                                                   Text="Waiting for live event stream..." />
            </StackPanel>
        </Border>

        <Border Padding="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                        <Border BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1">
                                <ScrollViewer x:Name="LiveOutputScrollViewer"
                                                          Height="520"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="LiveOutputText"
                                                           FontFamily="Consolas"
                                                           TextWrapping="NoWrap" />
                                </ScrollViewer>
                        </Border>
        </Border>
    </StackPanel>
</UserControl>