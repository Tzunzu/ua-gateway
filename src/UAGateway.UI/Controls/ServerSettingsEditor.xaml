<UserControl
    x:Class="UAGateway.UI.Controls.ServerSettingsEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Padding="12"
                Spacing="8">
        <TextBlock Text="Server Settings"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBlock Text="Configure the local OPC UA server endpoint used by downstream clients. Changes are saved immediately, but the service must restart before a new listener address is used."
                   Opacity="0.8"
                   TextWrapping="WrapWholeWords" />

        <Border Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel Spacing="10">
                <TextBlock Text="Local OPC UA listener"
                           FontSize="18"
                           FontWeight="SemiBold" />

                <TextBlock Text="Port"
                           FontWeight="SemiBold" />
                <TextBox x:Name="ServerPortTextBox"
                         Header="TCP port"
                         PlaceholderText="4840"
                         TextChanged="ServerPortTextBox_TextChanged" />

                <TextBlock Text="Host"
                           FontWeight="SemiBold" />
                <TextBox x:Name="ServerHostTextBox"
                         Header="Host or IP"
                         PlaceholderText="localhost"
                         TextChanged="ServerHostTextBox_TextChanged" />

                <TextBlock Text="Endpoint path"
                           FontWeight="SemiBold" />
                <TextBox x:Name="ServerEndpointPathTextBox"
                         Header="Path"
                         PlaceholderText="UAGateway"
                         TextChanged="ServerEndpointPathTextBox_TextChanged" />

                <TextBlock x:Name="ServerEndpointPreviewText"
                           Opacity="0.8"
                           TextWrapping="WrapWholeWords" />

                <TextBlock x:Name="ServerSettingsFilePathText"
                           Opacity="0.7"
                           TextWrapping="WrapWholeWords" />

                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="ReloadServerSettingsButton"
                            Content="Reload Configuration"
                            Click="ReloadServerSettingsButton_Click" />
                    <Button x:Name="RestoreServerSettingsDefaultsButton"
                        Content="Restore Defaults"
                        Click="RestoreServerSettingsDefaultsButton_Click" />
                    <Button x:Name="ApplyServerSettingsButton"
                            Content="Apply Configuration"
                            Click="ApplyServerSettingsButton_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock x:Name="ServerSettingsStatusText"
                   Opacity="0.8"
                   TextWrapping="WrapWholeWords" />
    </StackPanel>
</UserControl>